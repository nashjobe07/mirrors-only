{
  "name": "FAQItem",
  "type": "object",
  "properties": {
    "question": {
      "type": "string"
    },
    "answer": {
      "type": "string"
    },
    "category": {
      "type": "string"
    },
    "order_index": {
      "type": "number",
      "default": 0
    },
    "published": {
      "type": "boolean",
      "default": true
    }
  },
  "required": [
    "question"
  ]
}